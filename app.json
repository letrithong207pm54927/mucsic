{
  "expo": {
    "name": "MusicFinderApp",
    "slug": "MusicFinderApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "musicfinderapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.musicfinder",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Ứng dụng cần sử dụng Microphone để nhận diện lời bài hát của bạn.",
        "NSSpeechRecognitionUsageDescription": "Ứng dụng cần quyền nhận diện giọng nói để chuyển lời thoại thành văn bản."
      }
    },
    "android": {
      "package": "com.yourname.musicfinder",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Ứng dụng cần sử dụng Microphone để nhận diện lời bài hát của bạn.",
          "speechRecognitionPermission": "Ứng dụng cần quyền nhận diện giọng nói để chuyển lời thoại thành văn bản."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}